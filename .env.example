# --- required ---
DISCORD_TOKEN=your-discord-bot-token
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- LLM (optional but strongly recommended) ---
# If omitted, the bot still runs and falls back to non-LLM pattern summaries.
ANTHROPIC_API_KEY=your-anthropic-key
# Set this to whatever model you want to use. Cheap + fast is ideal for summaries.
LLM_MODEL=claude-haiku-4-5-20251001

# --- optional ---
# Default channel for posts. Can also be set at runtime with /setchannel.
UPDATE_CHANNEL_ID=
# Your Discord user id, for owner-only commands like /sync.
OWNER_ID=
# Path to the per-season config file.
SEASON_CONFIG=season.yaml
# Timezone used for hourly/daily scheduling and display.
TIMEZONE=US/Pacific
# LLM rate limits (requests per minute / hour).
LLM_RPM=10
LLM_RPH=100
